# Path to SSCD model weights (required for anime_searcher)
ATR_SSCD_MODEL_PATH=

# Optional FFmpeg overrides. On Arch Linux, prefer the system build for NVENC/NVDEC.
# If unset, the app falls back to the current pixi env, then .pixi/envs/default/bin, then PATH.
ATR_FFMPEG_BINARY=/usr/bin/ffmpeg
ATR_FFPROBE_BINARY=/usr/bin/ffprobe
# Minimum playback speed factor for non-raw source clips on the final timeline.
# Clips that would need to play slower than this leave a gap and go through gap resolution.
# The initial matcher floor is derived automatically as this value minus 0.10.
ATR_MIN_PLAYBACK_SPEED_FACTOR=0.75

# Account config path (per-account YouTube/Meta credentials + scheduling slots)
# Defaults to config/accounts/config.yaml in project root.
ATR_ACCOUNTS_CONFIG_PATH=

# TikTok server (VPS) integration
ATR_TIKTOK_SERVER_BASE_URL=https://tiktok.sididi.tv
ATR_TIKTOK_SERVER_INTERNAL_TOKEN=replace_me_match_vps

# Local CEP trigger URL template for "generation complete" notifications.
# Must include "{project_id}" placeholder.
ATR_CEP_TRIGGER_URL_TEMPLATE=http://localhost:48653/p/{project_id}

# Script automation (Gemini + ElevenLabs)
ATR_SCRIPT_AUTOMATE_ENABLED=true
# When false (default), metadata and video overlay generation are skipped during Automate.
# Set to true to generate social media metadata and title/category overlay.
ATR_AUTOMATE_METADATA_OVERLAY_ENABLED=false
# When true, /script title generation returns multiple choices and the UI asks
# the user to pick one. When false (default), the first choice is used automatically.
ATR_SCRIPT_TITLE_SELECTION_ENABLED=false
# When true, /script video overlay "title" is pre-filled statically based on
# the project library type (e.g. "CET ANIME EST INCROYABLE !") — no LLM call,
# no 8-proposition modal. Category stays user-editable.
ATR_STATIC_OVERLAY_TITLE_ENABLED=false
ATR_SCENES_SKIP_UI_ENABLED=false
ATR_TRANSCRIPTION_FULL_AUTO_ENABLED=false
ATR_GAPS_FULL_AUTO_ENABLED=false
# Auto-trigger the Fill button on /matches page when loading finishes (merge continuous must be active).
ATR_MATCHES_FULL_AUTO_ENABLED=false
# Auto-trigger Google Drive export after /processing completion.
# When true, automatic upload runs once per project; manual re-upload stays available.
ATR_PROCESSING_GDRIVE_FULL_AUTO_ENABLED=false
# OpenRouter (replaces ATR_GEMINI_*, ATR_ANTHROPIC_*, ATR_LLM_PROVIDER)
# Models are configured in config/llm/config.yaml; this only sets the API key.
ATR_OPENROUTER_API_KEY=your_openrouter_api_key
ATR_OPENROUTER_TIMEOUT=600

ATR_ELEVENLABS_API_KEY=your_elevenlabs_api_key
ATR_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ATR_ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Google OAuth credentials (shared for Drive + YouTube)
ATR_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
ATR_GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
ATR_GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token

# Split refresh tokens (recommended)
ATR_GOOGLE_DRIVE_REFRESH_TOKEN=your_drive_refresh_token
ATR_GOOGLE_YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token

# Legacy shared refresh token fallback (optional)
ATR_GOOGLE_REFRESH_TOKEN=

# Parent folder in Google Drive where project folders are created
ATR_GOOGLE_DRIVE_PARENT_FOLDER_ID=your_parent_folder_id
# Drive export speed tuning
ATR_DRIVE_UPLOAD_MAX_PARALLEL=4
ATR_DRIVE_DELETE_MAX_PARALLEL=8
ATR_DRIVE_UPLOAD_CHUNK_MB=16

# YouTube defaults
ATR_YOUTUBE_CATEGORY_ID=22
# Optional but recommended if the Google account has multiple YouTube channels.
# When set, uploads are enforced against this channel id.
ATR_YOUTUBE_CHANNEL_ID=
# Platform upload concurrency (YouTube/Facebook/Instagram)
ATR_SOCIAL_UPLOAD_MAX_PARALLEL=3
# Social upload networking/deadline tuning
ATR_SOCIAL_UPLOAD_HTTP_TIMEOUT_SECONDS=120
ATR_SOCIAL_UPLOAD_BINARY_TIMEOUT_SECONDS=900
ATR_SOCIAL_UPLOAD_PLATFORM_TIMEOUT_SECONDS=1200
# Whole-project upload concurrency in Project Manager
ATR_PROJECT_UPLOAD_MAX_CONCURRENT=3
# Queue backstop for the Project Manager platform-upload phase.
# Keep this slightly above ATR_SOCIAL_UPLOAD_PLATFORM_TIMEOUT_SECONDS.
ATR_PROJECT_MANAGER_PLATFORM_PHASE_TIMEOUT_SECONDS=1260

# Meta Graph API (Facebook + Instagram)
ATR_META_GRAPH_API_VERSION=v25.0
# Token mode:
# - system_user: use static ATR_FACEBOOK_PAGE_ACCESS_TOKEN (+ optional ATR_INSTAGRAM_ACCESS_TOKEN)
# - long_lived_user: provide user token + app credentials; server auto-refreshes token lifecycle
ATR_META_TOKEN_MODE=system_user
ATR_META_APP_ID=your_meta_app_id
ATR_META_APP_SECRET=your_meta_app_secret
ATR_META_USER_ACCESS_TOKEN=your_meta_user_access_token
# Optional ISO timestamp for the current user token expiry.
# Example: 2026-03-01T12:00:00+00:00
ATR_META_USER_ACCESS_TOKEN_EXPIRES_AT=
ATR_META_USER_TOKEN_REFRESH_LEAD_SECONDS=604800
ATR_FACEBOOK_PAGE_ID=your_facebook_page_id
ATR_FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
ATR_INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
# Optional in system_user mode; defaults to ATR_FACEBOOK_PAGE_ACCESS_TOKEN if empty.
ATR_INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
ATR_INSTAGRAM_PUBLISH_POLL_INTERVAL_SECONDS=5
ATR_INSTAGRAM_PUBLISH_TIMEOUT_SECONDS=900

# qBittorrent Web API (used for torrent linking, purge re-download, deferred download)
ATR_QBITTORRENT_URL=http://localhost:8080
ATR_QBITTORRENT_USERNAME=admin
ATR_QBITTORRENT_PASSWORD=adminadmin
# Directory where qBittorrent saves .torrent files (fallback for torrent linking)
ATR_TORRENT_COMPLETE_DIR=~/Torrents/.complete

# Hetzner Storage Box (canonical remote library releases)
ATR_STORAGE_BOX_ENABLED=true
ATR_STORAGE_BOX_HOST=
ATR_STORAGE_BOX_PORT=22
ATR_STORAGE_BOX_USERNAME=
ATR_STORAGE_BOX_SSH_KEY_PATH=
ATR_STORAGE_BOX_PASSWORD=
ATR_STORAGE_BOX_ROOT=
# Leave empty to use the default SSH known_hosts file (~/.ssh/known_hosts)
ATR_STORAGE_BOX_KNOWN_HOSTS_PATH=
ATR_LIBRARY_STATE_DB_PATH=backend/data/library_state.db
ATR_STORAGE_BOX_MAX_CONNECTIONS=3
ATR_STORAGE_BOX_UPLOAD_MAX_PARALLEL=2
ATR_STORAGE_BOX_DOWNLOAD_MAX_PARALLEL=3
# Bulk transfer mode for single-file transfers:
# - auto (default): prefer rsync over SSH when port 23 + SSH key auth are available; otherwise use SFTP
# - rsync: require rsync over SSH for single-file transfers
# - sftp: force SFTP for single-file transfers
# - lftp: force lftp for single-file transfers
# Directory uploads/downloads still prefer lftp mirror when lftp is installed and preflight succeeds.
ATR_STORAGE_BOX_TRANSFER_MODE=auto
ATR_STORAGE_BOX_RSYNC_MIN_FILE_SIZE_MB=16
ATR_STORAGE_BOX_RSYNC_TIMEOUT_SECONDS=7200
# lftp tuning for explicit lftp mode and directory mirror flows.
ATR_STORAGE_BOX_LFTP_SEGMENTS=4
# Reserved threshold for future lftp auto-selection benchmarking; auto currently uses rsync/sftp.
ATR_STORAGE_BOX_LFTP_MIN_FILE_SIZE_MB=50
